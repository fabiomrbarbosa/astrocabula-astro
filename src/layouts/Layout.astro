---
import { ui, defaultLang, HTML_LANG, type Lang } from "../i18n";

interface Props {
	title: string;
	lang?: Lang;
}

const { title, lang = defaultLang } = Astro.props;
const t = ui[lang];

// Lang switcher targets: same page in the other language, not the homepage.
// Astro.url.pathname may lack the trailing slash at build time — add it back
// (trailingSlash: "always").
const path = Astro.url.pathname.replace(/\/?$/, "/");
const basePath = lang === "pt" ? path.replace(/^\/pt/, "") || "/" : path;
const enHref = basePath;
const ptHref = basePath === "/" ? "/pt/" : `/pt${basePath}`;
---

<!doctype html>
<html lang={HTML_LANG[lang]}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="theme-color" content="#faf8f4" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} · {t.siteName}</title>
		<script>
			// PWA: dist/sw.js is generated post-build (scripts/generate-sw.mjs)
			// and precaches the whole site for offline use. It doesn't exist
			// under `astro dev`, hence production-only.
			if (import.meta.env.PROD && "serviceWorker" in navigator) {
				navigator.serviceWorker.register("/sw.js");
			}
		</script>
		<script is:inline>
			(function () {
				var STORAGE_KEY = "astrocabula-lang";
				var path = window.location.pathname;
				var isPt = path === "/pt" || path.indexOf("/pt/") === 0;
				var stored = localStorage.getItem(STORAGE_KEY);
				var target = null;

				if (stored === "pt" && !isPt) {
					target = "/pt" + path;
				} else if (stored === "en" && isPt) {
					target = path.replace(/^\/pt/, "") || "/";
				} else if (!stored) {
					var browserPt = (navigator.languages || [navigator.language]).some(
						function (l) {
							return l.toLowerCase().indexOf("pt") === 0;
						},
					);
					if (browserPt && !isPt) {
						localStorage.setItem(STORAGE_KEY, "pt");
						target = "/pt" + path;
					} else if (!browserPt && isPt) {
						localStorage.setItem(STORAGE_KEY, "en");
						target = path.replace(/^\/pt/, "") || "/";
					} else {
						localStorage.setItem(STORAGE_KEY, browserPt ? "pt" : "en");
					}
				}

				if (target) {
					window.location.replace(target);
				}
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href={lang === "pt" ? "/pt/" : "/"}>
				<span class="brand-full">{t.siteName}</span>
				<span class="brand-short">{t.siteNameShort}</span>
			</a>
			<nav>
				<a href={lang === "pt" ? "/pt/" : "/"}>{t.nav.dignities}</a>
				<a href={lang === "pt" ? "/pt/planets/" : "/planets/"}
					>{t.nav.planets}</a
				>
				<a href={lang === "pt" ? "/pt/signs/" : "/signs/"}>{t.nav.signs}</a>
				<span class="lang-switcher">
					<a
						href={enHref}
						class={lang === "en" ? "active" : ""}
						data-lang="en"
						aria-current={lang === "en" ? "true" : undefined}
					>
						EN
					</a>
					<a
						href={ptHref}
						class={lang === "pt" ? "active" : ""}
						data-lang="pt"
						aria-current={lang === "pt" ? "true" : undefined}
					>
						PT
					</a>
				</span>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>{t.footer}</p>
			<p>
				{t.builtBy}
				<a href="https://astrofabio.com" target="_blank" rel="noopener"
					>Fábio Barbosa</a
				>
			</p>
		</footer>
		<script is:inline>
			document.querySelectorAll(".lang-switcher a").forEach(function (a) {
				a.addEventListener("click", function () {
					localStorage.setItem("astrocabula-lang", a.dataset.lang || "en");
				});
			});
		</script>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: "Astronomicon";
		src: url("/fonts/Astronomicon.ttf") format("truetype");
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma1918";
		src: url("/fonts/Reforma1918/Reforma1918-Blanca.woff2") format("woff2");
		font-weight: 300;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma1918";
		src: url("/fonts/Reforma1918/Reforma1918-BlancaItalica.woff2")
			format("woff2");
		font-weight: 300;
		font-style: italic;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma1918";
		src: url("/fonts/Reforma1918/Reforma1918-Gris.woff2") format("woff2");
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma1918";
		src: url("/fonts/Reforma1918/Reforma1918-GrisItalica.woff2") format("woff2");
		font-weight: normal;
		font-style: italic;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma1918";
		src: url("/fonts/Reforma1918/Reforma1918-Negra.woff2") format("woff2");
		font-weight: bold;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma1918";
		src: url("/fonts/Reforma1918/Reforma1918-NegraItalica.woff2")
			format("woff2");
		font-weight: bold;
		font-style: italic;
		font-display: swap;
	}

	:root {
		color-scheme: light dark;
		--bg: #faf8f4;
		--fg: #2b2622;
		--muted: #756d64;
		--border: #c9bdac;
		--accent: #5c5347;
	}

	* {
		box-sizing: border-box;
	}

	html {
		/* The accordion computes scroll positions itself, accounting for
		   sections collapsing/expanding above the target — disable native
		   scroll anchoring so it doesn't double-correct and fight that. */
		overflow-anchor: none;
	}

	html,
	body {
		margin: 0;
		padding: 0;
	}

	body {
		font-family:
			"Reforma1918", "Iowan Old Style", Georgia, "Times New Roman", serif;
		background: var(--bg);
		color: var(--fg);
		line-height: 1.5;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		margin: -1px;
		padding: 0;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		padding: 1rem 1.5rem;
		border-bottom: 1px solid var(--border);
	}

	.site-header .brand {
		font-weight: bold;
		font-size: 1.25rem;
		color: var(--fg);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.brand-short {
		display: none;
	}

	.site-header nav {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.site-header nav a {
		color: var(--fg);
		text-decoration: none;
		font-size: 0.95rem;
	}

	.site-header nav a:hover {
		text-decoration: underline;
	}

	.lang-switcher {
		display: inline-flex;
		margin-left: 1rem;
		font-size: 0.85rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		overflow: hidden;
	}

	.lang-switcher a {
		margin-left: 0;
		padding: 0.2rem 0.65rem;
		color: var(--muted);
	}

	.lang-switcher a:hover {
		text-decoration: none;
		color: var(--fg);
	}

	.lang-switcher a.active {
		background: var(--accent);
		color: var(--bg);
		font-weight: bold;
	}

	main {
		margin: 0 auto;
		padding: 1.5rem;
	}

	.site-footer {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 1.5rem 2.5rem;
		color: var(--muted);
		font-size: 0.8rem;
	}

	.site-footer a {
		color: var(--accent);
	}

	.site-footer p + p {
		margin-top: 0.35rem;
	}

	@media (max-width: 600px) {
		.site-header {
			padding: 0.75rem 1rem;
		}

		.site-header nav {
			flex-grow: 1;
			justify-content: end;
			gap: 0.5rem;
		}

		.brand-full {
			display: none;
		}

		.brand-short {
			display: inline;
		}

		.site-header .brand {
			font-size: 1.1rem;
		}

		.site-header nav a {
			font-size: 0.85rem;
		}

		.lang-switcher {
			margin-left: 0.5rem;
		}
	}
</style>
