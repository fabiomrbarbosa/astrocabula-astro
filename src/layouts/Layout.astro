---
import { ui, defaultLang, HTML_LANG, type Lang } from "../i18n";

interface Props {
	title: string;
	lang?: Lang;
}

const { title, lang = defaultLang } = Astro.props;
const t = ui[lang];

// Lang switcher targets: same page in the other language, not the homepage.
// Astro.url.pathname may lack the trailing slash at build time — add it back
// (trailingSlash: "always").
const path = Astro.url.pathname.replace(/\/?$/, "/");
const basePath = lang === "pt" ? path.replace(/^\/pt/, "") || "/" : path;
const enHref = basePath;
const ptHref = basePath === "/" ? "/pt/" : `/pt${basePath}`;

const navItems = [
	{ href: lang === "pt" ? "/pt/" : "/", base: "/", label: t.nav.dignities },
	{
		href: lang === "pt" ? "/pt/planets/" : "/planets/",
		base: "/planets/",
		label: t.nav.planets,
	},
	{
		href: lang === "pt" ? "/pt/signs/" : "/signs/",
		base: "/signs/",
		label: t.nav.signs,
	},
].map((item) => ({ ...item, current: basePath === item.base }));

const currentNavItem = navItems.find((item) => item.current);
---

<!doctype html>
<html lang={HTML_LANG[lang]}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="theme-color" content="#faf8f4" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} · {t.siteName}</title>
		<script>
			// PWA: dist/sw.js is generated post-build (scripts/generate-sw.mjs)
			// and precaches the whole site for offline use. It doesn't exist
			// under `astro dev`, hence production-only.
			if (import.meta.env.PROD && "serviceWorker" in navigator) {
				navigator.serviceWorker.register("/sw.js");
			}
		</script>
		<script is:inline>
			(function () {
				var STORAGE_KEY = "astrocabula-lang";
				var path = window.location.pathname;
				var isPt = path === "/pt" || path.indexOf("/pt/") === 0;
				var stored = localStorage.getItem(STORAGE_KEY);
				var target = null;

				if (stored === "pt" && !isPt) {
					target = "/pt" + path;
				} else if (stored === "en" && isPt) {
					target = path.replace(/^\/pt/, "") || "/";
				} else if (!stored) {
					var browserPt = (navigator.languages || [navigator.language]).some(
						function (l) {
							return l.toLowerCase().indexOf("pt") === 0;
						},
					);
					if (browserPt && !isPt) {
						localStorage.setItem(STORAGE_KEY, "pt");
						target = "/pt" + path;
					} else if (!browserPt && isPt) {
						localStorage.setItem(STORAGE_KEY, "en");
						target = path.replace(/^\/pt/, "") || "/";
					} else {
						localStorage.setItem(STORAGE_KEY, browserPt ? "pt" : "en");
					}
				}

				if (target) {
					window.location.replace(target);
				}
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href={lang === "pt" ? "/pt/" : "/"}>
				<span class="brand-full">{t.siteName}</span>
				<span class="brand-short">{t.siteNameShort}</span>
			</a>
			<nav>
				<div class="nav-links">
					{
						navItems.map((item) => (
							<a
								href={item.href}
								class={item.current ? "active" : ""}
								aria-current={item.current ? "page" : undefined}
							>
								{item.label}
							</a>
						))
					}
				</div>
				<details class="nav-dropdown">
					<summary>
						<span>{currentNavItem?.label}</span>
						<span class="chevron" aria-hidden="true">
							<svg
								viewBox="0 0 16 16"
								width="10"
								height="10"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M3 6 L8 11 L13 6"></path>
							</svg>
						</span>
					</summary>
					<div class="nav-dropdown-menu">
						{
							navItems.map((item) => (
								<a
									href={item.href}
									class={item.current ? "active" : ""}
									aria-current={item.current ? "page" : undefined}
								>
									{item.label}
								</a>
							))
						}
					</div>
				</details>
				<span class="lang-switcher">
					<a
						href={enHref}
						class={lang === "en" ? "active" : ""}
						data-lang="en"
						aria-current={lang === "en" ? "true" : undefined}
					>
						EN
					</a>
					<a
						href={ptHref}
						class={lang === "pt" ? "active" : ""}
						data-lang="pt"
						aria-current={lang === "pt" ? "true" : undefined}
					>
						PT
					</a>
				</span>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>{t.footer}</p>
			<p>
				{t.builtBy}
				<a href="https://astrofabio.com" target="_blank" rel="noopener"
					>Fábio Barbosa</a
				>
			</p>
		</footer>
		<script is:inline>
			document.querySelectorAll(".lang-switcher a").forEach(function (a) {
				a.addEventListener("click", function () {
					localStorage.setItem("astrocabula-lang", a.dataset.lang || "en");
				});
			});

			document.addEventListener("click", function (e) {
				document.querySelectorAll(".nav-dropdown[open]").forEach(function (d) {
					if (!d.contains(e.target)) d.removeAttribute("open");
				});
			});
		</script>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: "Astronomicon";
		src: url("/fonts/Astronomicon.ttf") format("truetype");
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma2018";
		src: url("/fonts/Reforma2018/Reforma2018-Blanca.woff2") format("woff2");
		font-weight: 300;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma2018";
		src: url("/fonts/Reforma2018/Reforma2018-BlancaItalica.woff2")
			format("woff2");
		font-weight: 300;
		font-style: italic;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma2018";
		src: url("/fonts/Reforma2018/Reforma2018-Gris.woff2") format("woff2");
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma2018";
		src: url("/fonts/Reforma2018/Reforma2018-GrisItalica.woff2") format("woff2");
		font-weight: normal;
		font-style: italic;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma2018";
		src: url("/fonts/Reforma2018/Reforma2018-Negra.woff2") format("woff2");
		font-weight: bold;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Reforma2018";
		src: url("/fonts/Reforma2018/Reforma2018-NegraItalica.woff2")
			format("woff2");
		font-weight: bold;
		font-style: italic;
		font-display: swap;
	}

	:root {
		color-scheme: light dark;

		/* Neutral ramp, light → dark. No semantic meaning — components use
		   the aliases below, never the raw steps. --ink-rgb is the darkest
		   step as bare RGB channels, for rgba() alpha tints. */
		--neutral-0: #faf8f4;
		--neutral-1: #f7f4ee;
		--neutral-2: #f5f0e8;
		--neutral-3: #f0ebe2;
		--neutral-4: #e9e2d6;
		--neutral-5: #c9bdac;
		--neutral-6: #a89c8c;
		--neutral-7: #756c64;
		--neutral-8: #5c4e47;
		--neutral-9: #2b2422;
		--ink-rgb: 43, 36, 34;

		/* Semantic aliases */
		--bg: var(--neutral-0);
		--fg: var(--neutral-9);
		--muted: var(--neutral-7);
		--border: var(--neutral-5);
		--border-strong: var(--neutral-6);
		--accent: var(--neutral-8);
		--surface-active: var(--neutral-1);
		--surface-stripe: var(--neutral-2);
		--surface-head: var(--neutral-3);
		--surface-section: var(--neutral-4);
	}

	* {
		box-sizing: border-box;
	}

	html {
		/* The accordion computes scroll positions itself, accounting for
		   sections collapsing/expanding above the target — disable native
		   scroll anchoring so it doesn't double-correct and fight that. */
		overflow-anchor: none;
	}

	html,
	body {
		margin: 0;
		padding: 0;
	}

	body {
		font-family:
			"Reforma2018", "Iowan Old Style", Georgia, "Times New Roman", serif;
		font-weight: 300;
		background: var(--bg);
		color: var(--fg);
		line-height: 1.5;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		margin: -1px;
		padding: 0;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		padding: 1rem 1.5rem;
		border-bottom: 1px solid var(--border);
	}

	.site-header .brand {
		font-weight: bold;
		font-size: 1.25rem;
		color: var(--fg);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.brand-short {
		display: none;
	}

	.site-header nav {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.nav-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.25rem;
	}

	.nav-links a {
		color: var(--fg);
		text-decoration: none;
		font-size: 0.95rem;
		padding: 0.3rem 0.85rem;
		border-radius: 999px;
		transition:
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.nav-links a:hover,
	.nav-links a:focus-visible {
		background: var(--surface-head);
	}

	.nav-links a.active {
		background: var(--accent);
		color: var(--bg);
		font-weight: bold;
	}

	.nav-dropdown {
		display: none;
		position: relative;
	}

	.nav-dropdown summary {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		list-style: none;
		cursor: pointer;
		padding: 0.3rem 0.85rem;
		border-radius: 999px;
		background: var(--surface-head);
		font-size: 0.95rem;
		color: var(--fg);
	}

	.nav-dropdown summary::-webkit-details-marker {
		display: none;
	}

	.nav-dropdown .chevron {
		display: inline-flex;
		color: var(--muted);
		transition: transform 0.15s ease;
	}

	.nav-dropdown[open] .chevron {
		transform: rotate(180deg);
	}

	.nav-dropdown-menu {
		position: absolute;
		top: calc(100% + 0.35rem);
		left: 0;
		z-index: 10;
		display: flex;
		flex-direction: column;
		min-width: 9rem;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: 0 4px 12px rgba(var(--ink-rgb), 0.08);
	}

	.nav-dropdown-menu a {
		padding: 0.5rem 0.85rem;
		color: var(--fg);
		text-decoration: none;
		font-size: 0.9rem;
	}

	.nav-dropdown-menu a:hover,
	.nav-dropdown-menu a:focus-visible {
		background: var(--surface-active);
	}

	.nav-dropdown-menu a.active {
		font-weight: bold;
		background: var(--surface-active);
	}

	.lang-switcher {
		display: inline-flex;
		margin-left: 1rem;
		font-size: 0.85rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		overflow: hidden;
	}

	.lang-switcher a {
		margin-left: 0;
		padding: 0.2rem 0.65rem;
		color: var(--muted);
		text-decoration: none;
	}

	.lang-switcher a:hover {
		color: var(--fg);
	}

	.lang-switcher a.active {
		background: var(--accent);
		color: var(--bg);
		font-weight: bold;
	}

	main {
		margin: 0 auto;
		padding: 1.5rem;
	}

	.site-footer {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 1.5rem 2.5rem;
		color: var(--muted);
		font-size: 0.8rem;
	}

	.site-footer a {
		color: var(--accent);
	}

	.site-footer p + p {
		margin-top: 0.35rem;
	}

	@media (max-width: 600px) {
		.site-header {
			padding: 0.75rem 1rem;
		}

		.site-header nav {
			flex-grow: 1;
			justify-content: end;
			gap: 0.5rem;
		}

		.brand-full {
			display: none;
		}

		.brand-short {
			display: inline;
		}

		.site-header .brand {
			font-size: 1.1rem;
		}

		.nav-links {
			display: none;
		}

		.nav-dropdown {
			display: block;
		}

		.nav-dropdown summary,
		.nav-dropdown-menu a {
			font-size: 0.85rem;
		}

		.lang-switcher {
			margin-left: 0.5rem;
		}
	}
</style>
