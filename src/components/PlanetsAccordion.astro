---
import { PLANETS } from "../data/planets";
import { ui, defaultLang, type Lang } from "../i18n";
import { makeLabels, planetStyle, symbol } from "./dignities-shared";
import {
	domicileSigns,
	exaltationSign,
	makePlanetsLabels,
	toRoman,
} from "./planets-shared";
import { elementStyle } from "./signs-shared";
import AccordionItem from "./AccordionItem.astro";
import MobileAccordion from "./MobileAccordion.astro";
import PropsTable from "./PropsTable.astro";

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = ui[lang];
const pt = t.planetsTable;
const { name, signName } = makeLabels(lang);
const { text, weekday, years } = makePlanetsLabels(lang);
---

<MobileAccordion>
	{
		PLANETS.map((p) => (
			<AccordionItem
				group="planets"
				symbol={symbol(p.planet)}
				glyphStyle={planetStyle(p.planet)}
				label={name(p.planet)}
			>
				<section>
					<h3>{pt.sectionNature}</h3>
					<PropsTable>
						<span class="prop-label">{pt.qualities}</span>
						<span class="prop-value">{text(p.qualities)}</span>
						<span class="prop-label">{pt.temperament}</span>
						<span class="prop-value multiline">{text(p.temperament)}</span>
						<span class="prop-label">{pt.gender}</span>
						<span class="prop-value">{text(p.gender)}</span>
						<span class="prop-label">{pt.sect}</span>
						<span class="prop-value">{text(p.sect)}</span>
						<span class="prop-label">{pt.beneficMalefic}</span>
						<span class="prop-value">{text(p.benefic)}</span>
						<span class="prop-label">{pt.halfOrb}</span>
						<span class="prop-value">{p.halfOrb}°</span>
						<span class="prop-label">{pt.moiety}</span>
						<span class="prop-value">{p.moiety}°</span>
					</PropsTable>
				</section>
				<section>
					<h3>{pt.sectionAffinity}</h3>
					<PropsTable columns={2}>
						<span class="prop-label">{pt.friends}</span>
						<span class="prop-value">
							<span class="planet-chips">
								{p.friends.map((f) => (
									<span class="chip" style={planetStyle(f)} title={name(f)}>
										<span class="glyph">{symbol(f)}</span>
									</span>
								))}
							</span>
						</span>
						<span class="prop-label">{pt.enemies}</span>
						<span class="prop-value">
							<span class="planet-chips">
								{p.enemies.map((e) => (
									<span class="chip" style={planetStyle(e)} title={name(e)}>
										<span class="glyph">{symbol(e)}</span>
									</span>
								))}
							</span>
						</span>
					</PropsTable>
				</section>
				<section>
					<h3>{pt.sectionCycles}</h3>
					<PropsTable columns={4}>
						<span class="prop-label">{pt.avgSpeed}</span>
						<span class="prop-value">{p.avgSpeed}</span>
						<span class="prop-label">{pt.zodiacalCycle}</span>
						<span class="prop-value">{text(p.zodiacalCycle)}</span>
						<span class="prop-label">{pt.firdaria}</span>
						<span class="prop-value">{p.firdaria}</span>
						<span class="prop-label">{pt.agesOfMan}</span>
						<span class="prop-value">{text(p.agesOfMan)}</span>
					</PropsTable>
				</section>
				<section>
					<h3>{pt.sectionYears}</h3>
					<PropsTable columns={4}>
						<span class="prop-label">{pt.yearsMinor}</span>
						<span class="prop-value">{years(p.years.minor)}</span>
						<span class="prop-label">{pt.yearsMiddle}</span>
						<span class="prop-value">{years(p.years.middle)}</span>
						<span class="prop-label">{pt.yearsMajor}</span>
						<span class="prop-value">{years(p.years.major)}</span>
						<span class="prop-label">{pt.yearsMax}</span>
						<span class="prop-value">{years(p.years.max)}</span>
					</PropsTable>
				</section>
				<section>
					<h3>{pt.sectionRulerships}</h3>
					<PropsTable columns={3}>
						<span class="prop-label">{pt.houseOfJoy}</span>
						<span class="prop-value">{toRoman(p.houseOfJoy)}</span>
						<span class="prop-label">{pt.dayRuler}</span>
						<span class="prop-value">{weekday(p.dayRuler)}</span>
						<span class="prop-label">{pt.nightRuler}</span>
						<span class="prop-value">{weekday(p.nightRuler)}</span>
					</PropsTable>
					<PropsTable columns={2}>
						<span class="prop-label">{pt.domicile}</span>
						<span class="prop-value">
							<span class="planet-chips">
								{domicileSigns(p.planet).map((s) => (
									<span
										class="chip"
										style={elementStyle(s.element)}
										title={signName(s.sign)}
									>
										<span class="glyph">{s.symbol}</span>
									</span>
								))}
							</span>
						</span>
						<span class="prop-label">{pt.exaltation}</span>
						<span class="prop-value">
							{(() => {
								const sign = exaltationSign(p.planet);
								return (
									sign && (
										<span class="planet-chips">
											<span
												class="chip"
												style={elementStyle(sign.element)}
												title={signName(sign.sign)}
											>
												<span class="glyph">{sign.symbol}</span>
											</span>
										</span>
									)
								);
							})()}
						</span>
					</PropsTable>
				</section>
			</AccordionItem>
		))
	}
</MobileAccordion>

<style>
	section h3 {
		margin: 0 0 0.35rem;
		font-weight: 600;
		font-size: 0.8rem;
		text-transform: uppercase;
	}

	.glyph {
		font-family: "Astronomicon", serif;
		font-size: 1.75rem;
		line-height: 1.2;
		display: inline-block;
	}

	section :global(.props + .props) {
		margin-top: -1px;
	}

	.planet-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem;
		justify-content: center;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		border-radius: 0.25rem;
		border: 1px solid rgba(var(--ink-rgb), 0.2);
	}
</style>
