---
import { SIGN_ATTRIBUTES } from "../data/signs";
import { ui, defaultLang, type Lang } from "../i18n";
import { JOY_SIGNS, makeLabels } from "./dignities-shared";
import { dignitiesOf, elementStyle, makeSignsLabels } from "./signs-shared";
import AccordionItem from "./AccordionItem.astro";
import DegreeRuler from "./DegreeRuler.astro";
import DignityCell from "./DignityCell.astro";
import MobileAccordion from "./MobileAccordion.astro";
import PropsTable from "./PropsTable.astro";

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = ui[lang];
const st = t.signsTable;
const { signName } = makeLabels(lang);
const { text, elementName } = makeSignsLabels(lang);

const ROWS = SIGN_ATTRIBUTES.map((a) => ({ a, d: dignitiesOf(a.sign) }));
---

<MobileAccordion>
	{
		ROWS.map(({ a, d }) => (
			<AccordionItem
				group="signs"
				symbol={d.symbol}
				glyphStyle={elementStyle(d.element)}
				label={signName(d.sign)}
			>
				<section>
					<h3>{st.sectionNature}</h3>
					<PropsTable>
						<span class="prop-label">{st.qualities}</span>
						<span class="prop-value">{text(a.qualities)}</span>
						<span class="prop-label">{st.element}</span>
						<span class="prop-value">{elementName(d.element)}</span>
						<span class="prop-label">{st.temperament}</span>
						<span class="prop-value">{text(a.temperament)}</span>
						<span class="prop-label">{st.gender}</span>
						<span class="prop-value">{text(a.gender)}</span>
						<span class="prop-label">{st.sect}</span>
						<span class="prop-value">{text(a.sect)}</span>
						<span class="prop-label">{st.mode}</span>
						<span class="prop-value">{text(a.mode)}</span>
						<span class="prop-label">{st.season}</span>
						<span class="prop-value">{text(a.season)}</span>
					</PropsTable>
				</section>
				<div class="pair-row">
					<DignityCell
						lang={lang}
						planet={d.throne}
						label={st.ruler}
						joy={JOY_SIGNS.has(d.sign)}
					/>
					{d.exaltation && (
						<DignityCell
							lang={lang}
							planet={d.exaltation.planet}
							label={st.exaltation}
							degree={d.exaltation.degree}
						/>
					)}
				</div>
				<section>
					<h3>{st.triplicities}</h3>
					<div class="tri-row">
						<DignityCell
							lang={lang}
							planet={d.triplicity.day}
							label={t.table.day}
							role="day"
						/>
						<DignityCell
							lang={lang}
							planet={d.triplicity.night}
							label={t.table.night}
							role="night"
						/>
						<DignityCell
							lang={lang}
							planet={d.triplicity.participant}
							label={t.table.participant}
							role="participant"
						/>
					</div>
				</section>
				<section>
					<h3>{st.terms}</h3>
					<div class="ruler-host">
						<DegreeRuler lang={lang} entries={d.terms} fullTicks labels />
					</div>
				</section>
				<section>
					<h3>{st.faces}</h3>
					<div class="ruler-host">
						<DegreeRuler lang={lang} entries={d.faces} fullTicks labels />
					</div>
				</section>
				<section>
					<h3>{st.sectionAttributes}</h3>
					<PropsTable>
						<span class="prop-label">{st.behavior}</span>
						<span class="prop-value multiline">{text(a.behavior)}</span>
						<span class="prop-label">{st.voice}</span>
						<span class="prop-value">{text(a.voice)}</span>
						<span class="prop-label">{st.fertility}</span>
						<span class="prop-value">{text(a.fertility)}</span>
						<span class="prop-label">{st.flavor}</span>
						<span class="prop-value">{text(a.flavor)}</span>
						<span class="prop-label">{st.direction}</span>
						<span class="prop-value">{text(a.direction)}</span>
						<span class="prop-label">{st.ascension}</span>
						<span class="prop-value">{text(a.ascension)}</span>
						<span class="prop-label">{st.latitude}</span>
						<span class="prop-value">{text(a.latitude)}</span>
						<span class="prop-label">{st.commandObey}</span>
						<span class="prop-value">{text(a.commandObey)}</span>
						<span class="prop-label">{st.solarLunar}</span>
						<span class="prop-value">{text(a.solarLunar)}</span>
					</PropsTable>
				</section>
			</AccordionItem>
		))
	}
</MobileAccordion>

<style>
	section h3 {
		margin: 0 0 0.35rem;
		font-weight: 600;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.pair-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
	}

	/* Signs without an exaltation omit that cell — let the ruler cell take
	   the whole row. */
	.pair-row > :global(.cell:only-child) {
		grid-column: 1 / -1;
	}

	.tri-row {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 0.5rem;
	}

	.ruler-host {
		position: relative;
		height: 3.25rem;
		border: 1px solid var(--border);
	}
</style>
