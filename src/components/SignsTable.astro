---
import { SIGN_ATTRIBUTES } from "../data/signs";
import { ui, defaultLang, type Lang } from "../i18n";
import { makeLabels, planetStyle, symbol } from "./dignities-shared";
import { dignitiesOf, elementStyle, makeSignsLabels } from "./signs-shared";
import SignsAccordion from "./SignsAccordion.astro";

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = ui[lang];
const st = t.signsTable;
const { name, signName, dignityLabel, triplicityLabel } = makeLabels(lang);
const { text, elementName } = makeSignsLabels(lang);

// Each sign's PDF attributes paired with its dignities entry (ruler,
// exaltation, triplicities, terms, faces come from dignities.ts).
const ROWS = SIGN_ATTRIBUTES.map((a) => ({ a, d: dignitiesOf(a.sign) }));

const COLS = ROWS.length + 1;
---

<div class="table-wrap">
	<table class="signs">
		<colgroup>
			<col class="col-label" />
			{ROWS.map(() => <col class="col-sign" />)}
		</colgroup>
		<thead>
			<tr>
				<th class="col-label">{st.sign}</th>
				{
					ROWS.map(({ d }) => (
						<th
							class="col-sign"
							style={elementStyle(d.element)}
							title={signName(d.sign)}
						>
							<span class="glyph">{d.symbol}</span>
						</th>
					))
				}
			</tr>
		</thead>
		<tbody>
			<tr>
				<th colspan={COLS} scope="colgroup" class="section-header"
					>{st.sectionNature}</th
				>
			</tr>
			<tr>
				<th class="col-label">{st.qualities}</th>
				{ROWS.map(({ a }) => <td>{text(a.qualities)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.element}</th>
				{ROWS.map(({ d }) => <td>{elementName(d.element)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.temperament}</th>
				{ROWS.map(({ a }) => <td>{text(a.temperament)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.gender}</th>
				{ROWS.map(({ a }) => <td>{text(a.gender)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.sect}</th>
				{ROWS.map(({ a }) => <td>{text(a.sect)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.mode}</th>
				{ROWS.map(({ a }) => <td>{text(a.mode)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.season}</th>
				{ROWS.map(({ a }) => <td>{text(a.season)}</td>)}
			</tr>
		</tbody>
		<tbody>
			<tr>
				<th colspan={COLS} scope="colgroup" class="section-header"
					>{st.sectionDignities}</th
				>
			</tr>
			<tr>
				<th class="col-label">{st.ruler}</th>
				{
					ROWS.map(({ d }) => (
						<td>
							<div class="planet-chips">
								<span
									class="chip"
									style={planetStyle(d.throne)}
									title={name(d.throne)}
								>
									<span class="glyph">{symbol(d.throne)}</span>
								</span>
							</div>
						</td>
					))
				}
			</tr>
			<tr>
				<th class="col-label">{st.exaltation}</th>
				{
					ROWS.map(({ d }) => (
						<td>
							{d.exaltation && (
								<div class="planet-chips">
									<span
										class="chip"
										style={planetStyle(d.exaltation.planet)}
										title={dignityLabel(d.exaltation)}
									>
										<span class="glyph">{symbol(d.exaltation.planet)}</span>
									</span>
								</div>
							)}
						</td>
					))
				}
			</tr>
			<tr>
				<th class="col-label">{st.triplicities}</th>
				{
					ROWS.map(({ d }) => (
						<td>
							<div class="planet-chips">
								<span
									class="chip"
									style={planetStyle(d.triplicity.day)}
									title={triplicityLabel(d.triplicity.day, "day")}
								>
									<span class="glyph">{symbol(d.triplicity.day)}</span>
								</span>
								<span
									class="chip"
									style={planetStyle(d.triplicity.night)}
									title={triplicityLabel(d.triplicity.night, "night")}
								>
									<span class="glyph">{symbol(d.triplicity.night)}</span>
								</span>
								<span
									class="chip"
									style={planetStyle(d.triplicity.participant)}
									title={triplicityLabel(
										d.triplicity.participant,
										"participant",
									)}
								>
									<span class="glyph">{symbol(d.triplicity.participant)}</span>
								</span>
							</div>
						</td>
					))
				}
			</tr>
			<tr>
				<th class="col-label">{st.terms}</th>
				{
					ROWS.map(({ d }) => (
						<td>
							<div class="planet-chips">
								{d.terms.map((e) => (
									<span
										class="chip with-label"
										style={planetStyle(e.planet)}
										title={`${name(e.planet)} ${e.from}°–${e.to}°59′`}
									>
										<span class="glyph">{symbol(e.planet)}</span>
										<span class="chip-label">{e.from}°</span>
									</span>
								))}
							</div>
						</td>
					))
				}
			</tr>
			<tr>
				<th class="col-label">{st.faces}</th>
				{
					ROWS.map(({ d }) => (
						<td>
							<div class="planet-chips">
								{d.faces.map((e, i) => (
									<span
										class="chip with-label"
										style={planetStyle(e.planet)}
										title={`${name(e.planet)} ${e.from}°–${e.to}°59′`}
									>
										<span class="chip-label">{st.faceOrdinals[i]}</span>
										<span class="glyph">{symbol(e.planet)}</span>
									</span>
								))}
							</div>
						</td>
					))
				}
			</tr>
		</tbody>
		<tbody>
			<tr>
				<th colspan={COLS} scope="colgroup" class="section-header"
					>{st.sectionAttributes}</th
				>
			</tr>
			<tr>
				<th class="col-label">{st.behavior}</th>
				{ROWS.map(({ a }) => <td class="multiline">{text(a.behavior)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.voice}</th>
				{ROWS.map(({ a }) => <td>{text(a.voice)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.fertility}</th>
				{ROWS.map(({ a }) => <td>{text(a.fertility)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.flavor}</th>
				{ROWS.map(({ a }) => <td>{text(a.flavor)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.direction}</th>
				{ROWS.map(({ a }) => <td>{text(a.direction)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.ascension}</th>
				{ROWS.map(({ a }) => <td>{text(a.ascension)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.latitude}</th>
				{ROWS.map(({ a }) => <td>{text(a.latitude)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.commandObey}</th>
				{ROWS.map(({ a }) => <td>{text(a.commandObey)}</td>)}
			</tr>
			<tr>
				<th class="col-label">{st.solarLunar}</th>
				{ROWS.map(({ a }) => <td>{text(a.solarLunar)}</td>)}
			</tr>
		</tbody>
	</table>
</div>

<SignsAccordion lang={lang} />

<script>
	// Emulated sticky header: the overflow-x scroll container blocks real
	// page-relative position: sticky on the thead at any width, so a scroll
	// listener translates the header cells (and the shadow strip) by
	// --stick-y instead. Clamped so the header parks at the table's bottom
	// edge on the way out.
	document.querySelectorAll<HTMLElement>(".table-wrap").forEach((wrap) => {
		const thead = wrap.querySelector<HTMLElement>("thead");
		if (!thead) return;
		const update = () => {
			const y = Math.min(
				Math.max(0, -wrap.getBoundingClientRect().top),
				Math.max(0, wrap.clientHeight - thead.offsetHeight),
			);
			wrap.style.setProperty("--stick-y", `${y}px`);
			wrap.style.setProperty("--thead-h", `${thead.offsetHeight}px`);
			wrap.classList.toggle("stuck", y > 0);
		};
		addEventListener("scroll", update, { passive: true });
		addEventListener("resize", update);
		update();
	});
</script>

<style>
	/* overflow-y: hidden (not visible — that's impossible next to
	   overflow-x: auto) so the shadow strip's last 8px clip at the table's
	   bottom edge instead of growing a vertical scrollbar. No max-height /
	   inner vertical scroller on this table — the page scrolls. */
	.table-wrap {
		overflow-x: auto;
		overflow-y: hidden;
	}

	/* One full-width gradient shadow under the stuck header — same recipe
	   as the planets table. position: sticky; left: 0 pins it to the wrap's
	   visible left edge during horizontal scrolling (as an in-flow block its
	   width is the wrap's visible width, not the table's), and the
	   translateY rides --stick-y (set by the scroll listener below) to sit
	   just under the header cells. Zero net height (the negative margin
	   pulls it back out of layout); faded in via .stuck. */
	.table-wrap::before {
		content: "";
		display: block;
		position: sticky;
		left: 0;
		height: 8px;
		margin-bottom: -8px;
		transform: translateY(calc(var(--stick-y, 0px) + var(--thead-h, 0px)));
		background: linear-gradient(
			to bottom,
			rgba(var(--ink-rgb), 0.25),
			transparent
		);
		opacity: 0;
		transition: opacity 0.15s ease;
		pointer-events: none;
	}

	.table-wrap.stuck::before {
		opacity: 1;
	}

	@media (max-width: 767px) {
		.table-wrap {
			display: none;
		}
	}

	/* Separate (non-collapsed) borders, each owned by exactly one cell, so
	   the sticky header carries its borders with it — same scheme as the
	   planets table. */
	table.signs {
		--border: var(--border-strong);
		border-collapse: separate;
		border-spacing: 0;
		width: 100%;
		font-size: 0.8rem;
	}

	/* 0.3rem horizontal padding keeps three 1.75rem chips per row in the
	   6.5rem columns (triplicities, terms, faces). */
	table.signs th,
	table.signs td {
		border-bottom: 1px solid var(--border);
		border-left: 1px solid var(--border);
		padding: 0.5rem 0.3rem;
		text-align: center;
		vertical-align: middle;
	}

	/* Each border is owned by one cell: the label column keeps its right
	   border (the cell next to it drops its left border to compensate),
	   the last column closes the right edge, and the header row closes
	   the top. */
	table.signs .col-label + th,
	table.signs .col-label + td {
		border-left: none;
	}

	table.signs th.col-label {
		border-right: 1px solid var(--border);
	}

	table.signs th:last-child,
	table.signs td:last-child {
		border-right: 1px solid var(--border);
	}

	table.signs thead th {
		border-top: 1px solid var(--border);
	}

	/* 10rem + 12 × 6.5rem = 88rem, which (plus main's 3rem padding) is what
	   sets the 1460px fit breakpoint above. */
	col.col-label {
		width: 10rem;
	}

	col.col-sign {
		width: 6.5rem;
	}

	th.col-label {
		text-align: left;
		font-weight: 600;
		background: var(--surface-head);
	}

	td.multiline {
		white-space: pre-line;
	}

	thead th.col-label {
		text-transform: uppercase;
		font-size: 0.8rem;
		letter-spacing: 0.02em;
	}

	/* Emulated-sticky header cells — translated by --stick-y from the
	   scroll listener. Only the header row sticks; the label column scrolls
	   horizontally with the rest of the table. position: relative + z-index
	   lift the cells over the tbody column-stripe backgrounds. */
	table.signs thead th {
		position: relative;
		z-index: 2;
		transform: translateY(var(--stick-y, 0px));
	}

	th.section-header {
		background: var(--surface-section);
		text-align: left;
		text-transform: uppercase;
		font-size: 0.8rem;
		letter-spacing: 0.02em;
		padding: 0.4rem 0.6rem;
	}

	/* Alternating neutral column tones (instead of row zebra) — even table
	   columns get the tint, odd ones stay on the page background. Body cells
	   carry no element tint; only the thead is element-coded. */
	tbody td:nth-child(even) {
		background: var(--surface-stripe);
	}

	table.signs [title] {
		cursor: pointer;
	}

	.glyph {
		font-family: "Astronomicon", serif;
		font-size: 1.5rem;
		font-weight: normal;
		line-height: 1;
		display: inline-block;
	}

	.planet-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem;
		justify-content: center;
	}

	/* These include node chips, which have no planet color — the hairline
	   border gives them a visible box (and keeps pastel chips distinct on
	   the tinted stripe columns). */
	.chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		border-radius: 0.25rem;
		border: 1px solid rgba(var(--ink-rgb), 0.2);
		cursor: pointer;
	}

	/* Terms/faces chips carry a small text label beside the glyph (start
	   degree after it, face ordinal before it) — these grow horizontally
	   instead of staying square. */
	.chip.with-label {
		width: auto;
		padding: 0 0.3rem;
		gap: 0.2rem;
	}

	.chip-label {
		font-size: 0.7rem;
		line-height: 1;
	}
</style>
