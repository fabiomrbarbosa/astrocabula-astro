---
import { SIGNS } from "../data/dignities";
import { ui, defaultLang, type Lang } from "../i18n";
import { JOY_SIGNS, makeLabels } from "./dignities-shared";
import AccordionItem from "./AccordionItem.astro";
import DegreeRuler from "./DegreeRuler.astro";
import DignityCell from "./DignityCell.astro";
import MobileAccordion from "./MobileAccordion.astro";
import { elementStyle } from "./signs-shared";

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = ui[lang];
const { signName } = makeLabels(lang);
---

<MobileAccordion>
	{
		SIGNS.map((s) => (
			<AccordionItem
				group="dignities"
				symbol={s.symbol}
				glyphStyle={elementStyle(s.element)}
				label={signName(s.sign)}
			>
				<div class="pair-row">
					<DignityCell
						lang={lang}
						planet={s.throne}
						label={`${t.table.throne} +5`}
						joy={JOY_SIGNS.has(s.sign)}
					/>
					{s.exaltation && (
						<DignityCell
							lang={lang}
							planet={s.exaltation.planet}
							label={`${t.table.exaltFull} +4`}
							degree={s.exaltation.degree}
						/>
					)}
				</div>
				<section>
					<h3>{t.table.triplicities} +3</h3>
					<div class="tri-row">
						<DignityCell
							lang={lang}
							planet={s.triplicity.day}
							label={t.table.day}
							role="day"
						/>
						<DignityCell
							lang={lang}
							planet={s.triplicity.night}
							label={t.table.night}
							role="night"
						/>
						<DignityCell
							lang={lang}
							planet={s.triplicity.participant}
							label={t.table.participant}
							role="participant"
						/>
					</div>
				</section>
				<section>
					<h3>{t.table.terms} +2</h3>
					<div class="ruler-host">
						<DegreeRuler lang={lang} entries={s.terms} fullTicks labels />
					</div>
				</section>
				<section>
					<h3>{t.table.faces} +1</h3>
					<div class="ruler-host">
						<DegreeRuler lang={lang} entries={s.faces} fullTicks labels />
					</div>
				</section>
				<div class="pair-row">
					<DignityCell
						lang={lang}
						planet={s.exile}
						label={`${t.table.exile} −5`}
					/>
					{s.fall && (
						<DignityCell
							lang={lang}
							planet={s.fall.planet}
							label={`${t.table.fall} −4`}
							degree={s.fall.degree}
						/>
					)}
				</div>
				<section>
					<h3>{t.table.almuten}</h3>
					<div class="ruler-host">
						<DegreeRuler lang={lang} entries={s.almuten} fullTicks labels />
					</div>
				</section>
			</AccordionItem>
		))
	}
</MobileAccordion>

<style>
	section h3 {
		margin: 0 0 0.35rem;
		font-weight: 600;
		font-size: 0.8rem;
		text-transform: uppercase;
	}

	.pair-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
	}

	/* Signs without an exaltation/fall omit that cell — let the remaining
	   throne/exile cell take the whole row. */
	.pair-row > :global(.cell:only-child) {
		grid-column: 1 / -1;
	}

	.tri-row {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 0.5rem;
	}

	.ruler-host {
		position: relative;
		height: 3.25rem;
		border: 1px solid var(--border);
	}
</style>
