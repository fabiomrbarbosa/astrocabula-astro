---
import { SIGNS } from "../data/dignities";
import { ui, defaultLang, type Lang } from "../i18n";
import {
	FIVE_DEGREE_TICKS,
	JOY_SIGNS,
	TEN_DEGREE_TICKS,
	makeLabels,
	planetStyle,
	symbol,
} from "./dignities-shared";
import DegreeRuler from "./DegreeRuler.astro";
import DignitiesAccordion from "./DignitiesAccordion.astro";

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = ui[lang];
const { name, signName, dignityLabel, triplicityLabel, joyLabel } =
	makeLabels(lang);
---

<div class="table-wrap">
	<div class="sticky-shadow sticky-shadow-start" aria-hidden="true"></div>
	<div class="sticky-shadow sticky-shadow-end" aria-hidden="true"></div>
	<table class="dignities">
		<colgroup>
			<col class="col-sign" />
			<col class="col-throne" />
			<col class="col-exalt" />
			<col class="col-triplicity" />
			<col class="col-triplicity" />
			<col class="col-triplicity" />
			<col class="col-terms" />
			<col class="col-faces" />
			<col class="col-exile" />
			<col class="col-fall" />
			<col class="col-almuten" />
			<col class="col-sign-end" />
		</colgroup>
		<thead>
			<tr>
				<th rowspan="2" class="col-sign">{t.table.sign}</th>
				<th rowspan="2" class="col-throne">{t.table.throne}</th>
				<th rowspan="2" class="col-exalt">{t.table.exalt}</th>
				<th colspan="3" class="col-triplicity">{t.table.triplicities}</th>
				<th class="col-terms">{t.table.terms}</th>
				<th class="col-faces">{t.table.faces}</th>
				<th rowspan="2" class="col-exile">{t.table.exile}</th>
				<th rowspan="2" class="col-fall">{t.table.fall}</th>
				<th class="col-almuten">{t.table.almuten}</th>
				<th rowspan="2" class="col-sign-end">{t.table.sign}</th>
			</tr>
			<tr>
				<th class="col-triplicity sub">{t.table.day}</th>
				<th class="col-triplicity sub">{t.table.night}</th>
				<th class="col-triplicity sub">{t.table.participant}</th>
				<th class="col-terms sub ruler-header">
					<div class="ruler header-ruler">
						<div class="ticks">
							{
								FIVE_DEGREE_TICKS.map((i) => (
									<span
										class="tick medium"
										style={`left: ${(i / 30) * 100}%`}
									/>
								))
							}
						</div>
						<div class="tick-labels">
							{
								FIVE_DEGREE_TICKS.map((i) => (
									<span class="tick-label" style={`left: ${(i / 30) * 100}%`}>
										{i}°
									</span>
								))
							}
						</div>
					</div>
				</th>
				<th class="col-faces sub ruler-header">
					<div class="ruler header-ruler">
						<div class="ticks">
							{
								TEN_DEGREE_TICKS.map((i) => (
									<span
										class="tick medium"
										style={`left: ${(i / 30) * 100}%`}
									/>
								))
							}
						</div>
						<div class="tick-labels">
							{
								TEN_DEGREE_TICKS.map((i) => (
									<span class="tick-label" style={`left: ${(i / 30) * 100}%`}>
										{i}°
									</span>
								))
							}
						</div>
					</div>
				</th>
				<th class="col-almuten sub ruler-header">
					<div class="ruler header-ruler">
						<div class="ticks">
							{
								FIVE_DEGREE_TICKS.map((i) => (
									<span
										class="tick medium"
										style={`left: ${(i / 30) * 100}%`}
									/>
								))
							}
						</div>
						<div class="tick-labels">
							{
								FIVE_DEGREE_TICKS.map((i) => (
									<span class="tick-label" style={`left: ${(i / 30) * 100}%`}>
										{i}°
									</span>
								))
							}
						</div>
					</div>
				</th>
			</tr>
		</thead>
		<tfoot>
			<tr class="score-row">
				<td class="col-sign">{t.table.score}</td>
				<td class="col-throne">+5</td>
				<td class="col-exalt">+4</td>
				<td class="col-triplicity sub" colspan="3">+3</td>
				<td class="col-terms">+2</td>
				<td class="col-faces">+1</td>
				<td class="col-exile">−5</td>
				<td class="col-fall">−4</td>
				<td class="col-almuten">{t.table.almuten}</td>
				<td class="col-sign-end">{t.table.score}</td>
			</tr>
		</tfoot>
		<tbody>
			{
				SIGNS.map((s) => (
					<tr>
						<td class="col-sign" title={signName(s.sign)}>
							<span class="glyph">{s.symbol}</span>
						</td>
						<td
							class="col-throne"
							style={planetStyle(s.throne)}
							title={
								JOY_SIGNS.has(s.sign) ? joyLabel(s.throne) : name(s.throne)
							}
						>
							<span class="glyph">{symbol(s.throne)}</span>
							{JOY_SIGNS.has(s.sign) && <span class="tri-label">J</span>}
						</td>
						<td
							class="col-exalt"
							style={
								s.exaltation ? planetStyle(s.exaltation.planet) : undefined
							}
							title={s.exaltation ? dignityLabel(s.exaltation) : undefined}
						>
							{s.exaltation ? (
								<>
									<span class="glyph">{symbol(s.exaltation.planet)}</span>
									{s.exaltation.degree !== undefined && (
										<sup>{s.exaltation.degree}°</sup>
									)}
								</>
							) : (
								<span class="empty">—</span>
							)}
						</td>
						<td
							class="col-triplicity sub"
							style={planetStyle(s.triplicity.day)}
							title={triplicityLabel(s.triplicity.day, "day")}
						>
							<span class="glyph">{symbol(s.triplicity.day)}</span>
							<span class="tri-label">D</span>
						</td>
						<td
							class="col-triplicity sub"
							style={planetStyle(s.triplicity.night)}
							title={triplicityLabel(s.triplicity.night, "night")}
						>
							<span class="glyph">{symbol(s.triplicity.night)}</span>
							<span class="tri-label">N</span>
						</td>
						<td
							class="col-triplicity sub"
							style={planetStyle(s.triplicity.participant)}
							title={triplicityLabel(s.triplicity.participant, "participant")}
						>
							<span class="glyph">{symbol(s.triplicity.participant)}</span>
							<span class="tri-label">P</span>
						</td>
						<td class="col-terms">
							<DegreeRuler lang={lang} entries={s.terms} fullTicks labels />
						</td>
						<td class="col-faces">
							<DegreeRuler lang={lang} entries={s.faces} />
						</td>
						<td
							class="col-exile"
							style={planetStyle(s.exile)}
							title={name(s.exile)}
						>
							<span class="glyph">{symbol(s.exile)}</span>
						</td>
						<td
							class="col-fall"
							style={s.fall ? planetStyle(s.fall.planet) : undefined}
							title={s.fall ? dignityLabel(s.fall) : undefined}
						>
							{s.fall ? (
								<>
									<span class="glyph">{symbol(s.fall.planet)}</span>
									{s.fall.degree !== undefined && <sup>{s.fall.degree}°</sup>}
								</>
							) : (
								<span class="empty">—</span>
							)}
						</td>
						<td class="col-almuten">
							<DegreeRuler lang={lang} entries={s.almuten} fullTicks labels />
						</td>
						<td class="col-sign-end" title={signName(s.sign)}>
							<span class="glyph">{s.symbol}</span>
						</td>
					</tr>
				))
			}
		</tbody>
	</table>
</div>

<DignitiesAccordion lang={lang} />

<style>
	.table-wrap {
		--cell-min-width: 5rem;
		display: grid;
		overflow-x: auto;
	}

	/* Below 768px the table is replaced by the accordion (DignitiesAccordion.astro
	   carries the mirror-image rule). Both stay in the DOM — static site. */
	@media (max-width: 767px) {
		.table-wrap {
			display: none;
		}
	}

	.table-wrap > table,
	.table-wrap > .sticky-shadow {
		grid-area: 1 / 1;
	}

	.sticky-shadow {
		position: sticky;
		top: 0;
		width: 8px;
		pointer-events: none;
		z-index: 1;
		opacity: 0;
		transition: opacity 0.15s ease;
	}

	.sticky-shadow-start {
		left: calc(var(--cell-min-width) - 1px);
		background: linear-gradient(to right, rgba(43, 38, 34, 0.25), transparent);
	}

	.sticky-shadow-end {
		right: calc(var(--cell-min-width) - 1px);
		justify-self: end;
		background: linear-gradient(to left, rgba(43, 38, 34, 0.25), transparent);
	}

	.table-wrap.scrolled .sticky-shadow-start {
		opacity: 1;
	}

	.table-wrap.scrolled-end .sticky-shadow-end {
		opacity: 1;
	}

	table.dignities {
		--border: #a89c8c;
		--tick-spacing: 0.25rem;
		table-layout: fixed;
		border-collapse: collapse;
		border-top: 1px solid var(--border);
		border-right: 1px solid var(--border);
		width: 100%;
		min-width: 1100px;
		font-size: 0.75rem;
	}

	table.dignities th,
	table.dignities td {
		border-bottom: 1px solid var(--border);
		border-left: 1px solid var(--border);
		text-align: center;
		vertical-align: middle;
	}

	table.dignities [title] {
		cursor: pointer;
	}

	table.dignities th {
		padding: 0.4rem 0.5rem;
		overflow-wrap: break-word;
	}

	table.dignities td {
		padding: 0;
		min-width: var(--cell-min-width);
	}

	table.dignities thead th {
		background: #f0ebe2;
		font-weight: 600;
		font-size: 0.8rem;
		text-transform: uppercase;
	}

	thead th.sub {
		text-transform: none;
		font-size: 0.75rem;
	}

	table.dignities th.ruler-header {
		padding: 0;
		position: relative;
	}

	/* Header rulers (degree scales in thead) are table-local — body rulers
	   live in DegreeRuler.astro, whose scoped styles don't reach these. */
	.ruler.header-ruler {
		position: absolute;
		inset: 0;
	}

	.header-ruler .ticks {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.header-ruler .ticks .tick {
		position: absolute;
		bottom: 0;
		width: 1px;
		height: 0.5rem;
		background: rgba(43, 38, 34, 0.3);
	}

	.header-ruler .tick-labels {
		position: absolute;
		inset: 0;
		font-weight: 400;
		text-transform: none;
		letter-spacing: normal;
		color: var(--fg);
	}

	.header-ruler .tick-labels .tick-label {
		position: absolute;
		top: var(--tick-spacing);
		transform: translateX(-50%);
		white-space: nowrap;
	}

	td.col-sign {
		text-align: center;
	}

	th.col-sign,
	td.col-sign {
		position: sticky;
		left: 0;
		z-index: 2;
	}

	/* border-collapse doesn't carry the col-throne border-left along with
	   the sticky col-sign cell as it scrolls — re-paint it as a box-shadow
	   on col-sign itself once scrolled (avoids a double border when not
	   scrolled, where the collapsed border already shows). */
	.table-wrap.scrolled th.col-sign,
	.table-wrap.scrolled td.col-sign {
		box-shadow: inset -1px 0 0 0 var(--border);
	}

	td.col-sign {
		background: var(--bg);
	}

	tbody tr:nth-child(even) td.col-sign {
		background: #f5f0e8;
	}

	.table-wrap.scrolled {
		border-left: 1px solid var(--border);
	}

	td.col-sign-end {
		text-align: center;
	}

	th.col-sign-end,
	td.col-sign-end {
		position: sticky;
		/* -1px compensates for a sub-pixel rounding gap between the sticky
		   column and the scroll container's edge under border-collapse. */
		right: -1px;
		z-index: 2;
	}

	/* border-collapse doesn't carry the col-almuten border-right along with
	   the sticky col-sign-end cell as it scrolls — re-paint it as a
	   box-shadow on col-sign-end itself once scrolled (avoids a double
	   border when not scrolled, where the collapsed border already shows). */
	.table-wrap.scrolled-end th.col-sign-end,
	.table-wrap.scrolled-end td.col-sign-end {
		box-shadow: inset 1px 0 0 0 var(--border);
	}

	td.col-sign-end {
		background: var(--bg);
	}

	tbody tr:nth-child(even) td.col-sign-end {
		background: #f5f0e8;
	}

	.table-wrap.scrolled-end {
		border-right: 1px solid var(--border);
	}

	col.col-sign,
	col.col-sign-end,
	col.col-throne,
	col.col-exalt,
	col.col-triplicity,
	col.col-exile,
	col.col-fall {
		width: var(--cell-min-width);
	}

	col.col-terms,
	col.col-almuten {
		width: 25rem;
	}

	col.col-faces {
		width: calc(var(--cell-min-width) * 3);
	}

	td.col-terms,
	td.col-faces,
	td.col-almuten,
	td.col-triplicity,
	td.col-throne {
		position: relative;
	}

	.tri-label {
		position: absolute;
		right: var(--tick-spacing);
		bottom: var(--tick-spacing);
		line-height: 1;
	}

	.glyph {
		font-family: "Astronomicon", serif;
		font-size: 1.75rem;
		line-height: 2.25;
		display: inline-block;
	}

	.empty {
		color: var(--muted);
	}

	td.col-exalt sup,
	td.col-fall sup {
		font-size: 1em;
	}

	tbody tr:nth-child(even) {
		background: #f5f0e8;
	}

	table.dignities tfoot td {
		padding: 1rem 0.5rem;
		font-size: 0.8rem;
		font-weight: 600;
		background: #f0ebe2;
	}

	.score-row {
		text-transform: uppercase;
	}

	/* Opacity animation when hovering */

	table.dignities tbody td:not(.col-sign):not(.col-sign-end) {
		transition: opacity 0.15s ease;
	}

	table.dignities:has(tbody tr:hover)
		tbody
		td:not(.col-sign):not(.col-sign-end) {
		opacity: 0.25;
	}

	table.dignities tbody tr:hover td:not(.col-sign):not(.col-sign-end) {
		opacity: 1;
	}
</style>

<script>
	function setupStickySignShadow(wrap: HTMLElement) {
		const update = () => {
			wrap.classList.toggle("scrolled", wrap.scrollLeft > 0);
			const maxScroll = wrap.scrollWidth - wrap.clientWidth;
			wrap.classList.toggle("scrolled-end", wrap.scrollLeft < maxScroll - 1);
		};
		wrap.addEventListener("scroll", update, { passive: true });
		// Re-check on resize: if the page loads at mobile width the wrap is
		// display:none (zero dimensions), so the initial update() is a no-op.
		window.addEventListener("resize", update, { passive: true });
		update();
	}

	document
		.querySelectorAll<HTMLElement>(".table-wrap")
		.forEach(setupStickySignShadow);
</script>
